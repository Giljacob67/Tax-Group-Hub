# Tax Group AI Hub — Environment Variables
# Copy this file to .env and fill in the values

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Create a free project at https://neon.tech (or via Vercel Marketplace → Storage → Neon)
# Then enable pgvector: run "CREATE EXTENSION IF NOT EXISTS vector;" in the Neon SQL console
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── LLM APIs ────────────────────────────────────────────────────────────────
# Primary LLM provider (required for agent chat)
OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini — image generation + semantic search embeddings
GEMINI_API_KEY=AIza...

# ─── Optional LLM overrides ──────────────────────────────────────────────────
# Default model used for chat (can be changed in the UI)
OPENROUTER_MODEL=google/gemini-flash-1.5

# Local Ollama instance (optional — cloud deployments can omit this)
OLLAMA_URL=
OLLAMA_MODEL=llama3.2

# ─── App ─────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL — used for CORS in production
APP_URL=https://tax-group-hub.vercel.app

# Local development ports (optional — defaults shown below)
PORT=3011

# ─── Security ────────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of API keys stored in DB (BYOK)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Auth bypass for LOCAL DEVELOPMENT ONLY (never works in production)
# DEV_BYPASS_AUTH=true
