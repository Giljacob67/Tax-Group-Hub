# Tax Group AI Hub — Environment Variables
# Copy this file to .env and fill in the values
#
# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTION: Set these in Vercel Dashboard → Settings → Environment Variables
# NEVER commit .env.production.local or .env.local to git.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Create a free project at https://neon.tech (or via Vercel Marketplace → Storage → Neon)
# Then enable pgvector: run "CREATE EXTENSION IF NOT EXISTS vector;" in the Neon SQL console
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Unpooled connection for migrations (Neon requires this for long-running queries)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── Security (REQUIRED IN PRODUCTION) ───────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of API keys stored in DB (BYOK)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Authentication (REQUIRED IN PRODUCTION) ─────────────────────────────────
# At least one of JWT_SECRET or API_KEY MUST be set in production.
# Without either, the auth middleware returns 401 for all protected routes.
#
# JWT secret for token signing (min 32 chars recommended)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Static API key for service-to-service auth (alternative or complement to JWT)
# Generate with: openssl rand -hex 32
API_KEY=

# ─── Cron & Webhooks (REQUIRED IN PRODUCTION) ────────────────────────────────
# Secret for Vercel Cron job endpoints (Authorization: Bearer <CRON_SECRET>)
# Vercel sends this automatically for cron jobs defined in vercel.json
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Shared secret for incoming webhook validation (Telegram, WhatsApp, Make.com)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# Service user ID for cron/webhook requests (default: "service")
# SERVICE_USER_ID=service

# ─── App ─────────────────────────────────────────────────────────────────────
# Your Vercel FRONTEND deployment URL — used for CORS in production
# This MUST match the origin the browser sends requests from.
APP_URL=https://tax-group-hub.vercel.app

# Local development ports (optional — defaults shown below)
PORT=3011

# CORS allowed origins (comma-separated; overrides APP_URL in production)
CORS_ORIGINS=

# ─── LLM APIs (required for AI features) ────────────────────────────────────
# Google Gemini — embeddings + agent chat (required for semantic search)
GEMINI_API_KEY=AIza...

# ─── Optional LLM overrides ──────────────────────────────────────────────────
# Local Ollama instance (optional — cloud deployments can omit this)
OLLAMA_URL=
OLLAMA_MODEL=llama3.2

# ─── Additional LLM Providers ─────────────────────────────────────────────────
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (used for Whisper transcription and GPT models)
OPENAI_API_KEY=sk-...

# Perplexity Sonar (used by agent tool: web search)
PERPLEXITY_API_KEY=pplx-...

# Resend (transactional email from agent tool)
RESEND_API_KEY=re_...

# Email sender address used by the email agent tool (defaults to agent@taxgroup-hub.ai)
EMAIL_SENDER=

# EmpresaQui CNPJ enrichment API
EMPRESAQUI_API_KEY=

# ─── Optional overrides ───────────────────────────────────────────────────────
# Default Gemini model for image generation (default: gemini-2.0-flash-exp-image-generation)
GEMINI_MODEL=

# Ollama Cloud URL (for cloud-hosted Ollama deployments)
OLLAMA_CLOUD_URL=

# Pino log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Vercel Blob — upload de arquivos grandes (> 3MB)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# API base URL for the frontend (empty = same origin)
# VITE_API_URL=

# ⚠️ DO NOT SET IN PRODUCTION — this variable is unused and was a development artifact.
# VITE_BYPASS_AUTH=
