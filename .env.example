# Tax Group AI Hub — Environment Variables
# Copy this file to .env and fill in the values

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Create a free project at https://neon.tech (or via Vercel Marketplace → Storage → Neon)
# Then enable pgvector: run "CREATE EXTENSION IF NOT EXISTS vector;" in the Neon SQL console
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── LLM APIs ────────────────────────────────────────────────────────────────
# Primary LLM provider (required for agent chat)
OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini — image generation + semantic search embeddings
GEMINI_API_KEY=AIza...

# ─── Optional LLM overrides ──────────────────────────────────────────────────
# Default model used for chat (can be changed in the UI)
OPENROUTER_MODEL=google/gemini-flash-1.5

# Local Ollama instance (optional — cloud deployments can omit this)
OLLAMA_URL=
OLLAMA_MODEL=llama3.2

# ─── App ─────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL — used for CORS in production
APP_URL=https://tax-group-hub.vercel.app

# Local development ports (optional — defaults shown below)
PORT=3011

# ─── Security ────────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of API keys stored in DB (BYOK)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Auth bypass for LOCAL DEVELOPMENT ONLY (never works in production)
# DEV_BYPASS_AUTH=true

# ─── Authentication ───────────────────────────────────────────────────────────
# JWT secret for token signing (required in production; min 32 chars)
JWT_SECRET=

# Static API key alternative to JWT (simpler single-user setups)
API_KEY=

# ─── Additional LLM Providers ─────────────────────────────────────────────────
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (used for Whisper transcription and GPT models)
OPENAI_API_KEY=sk-...

# Tavily search (used by agent tool: web search)
TAVILY_API_KEY=tvly-...

# Resend (transactional email from agent tool)
RESEND_API_KEY=re_...

# EmpresaQui CNPJ enrichment API
EMPRESAQUI_API_KEY=

# ─── Webhooks & Integrations ──────────────────────────────────────────────────
# Shared secret for incoming webhook validation (Telegram, WhatsApp, etc.)
WEBHOOK_SECRET=

# Secret for protecting cron job endpoints
CRON_SECRET=

# CORS allowed origins (comma-separated; overrides APP_URL in production)
CORS_ORIGINS=

# ─── Optional overrides ───────────────────────────────────────────────────────
# Default Gemini model for image generation (default: gemini-2.0-flash-exp-image-generation)
GEMINI_MODEL=

# Ollama Cloud URL (for cloud-hosted Ollama deployments)
OLLAMA_CLOUD_URL=

# Pino log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
