{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm run build && node scripts/apply-migrations.mjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "artifacts/tax-group-hub/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/automate/process-sequences",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/automate/trigger/reforma-tributaria",
      "schedule": "0 8 * * 1-5"
    },
    {
      "path": "/api/knowledge/process-queue",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/integrations/hubspot/sync",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
